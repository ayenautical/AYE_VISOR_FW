#pragma once

// ── SSID del POD da cercare via ESP-NOW scan ──────────────────────────────
// Formato: "AYE_POD_XXX" dove XXX è il numero del dispositivo
#define TARGET_POD_SSID   "AYE_POD_XXX"

// ── Identificativo visore ─────────────────────────────────────────────────
#define NOME_VISORE       "AYE_VISOR_XXX"

// ── PIN crew (mostrato nella schermata Info) ──────────────────────────────
// Stringa di max 8 caratteri numerici
#define CREW_PIN          "00000000"
